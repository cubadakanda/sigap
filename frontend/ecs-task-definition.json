{
  "family": "sigap-frontend-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "sigap-frontend",
      "image": "ACCOUNT_ID.dkr.ecr.ap-southeast-1.amazonaws.com/sigap-frontend:latest",
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "VITE_API_BASE_URL",
          "value": "https://api.yourdomain.com/api"
        },
        {
          "name": "VITE_CLOUDFRONT_URL",
          "value": "https://d12345abcde.cloudfront.net"
        },
        {
          "name": "VITE_APP_NAME",
          "value": "SIGAP"
        },
        {
          "name": "VITE_MAP_CENTER_LAT",
          "value": "-6.2088"
        },
        {
          "name": "VITE_MAP_CENTER_LNG",
          "value": "106.8456"
        },
        {
          "name": "VITE_MAP_ZOOM",
          "value": "12"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/sigap-frontend",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:3000 || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ],
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole"
}
