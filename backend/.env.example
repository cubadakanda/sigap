# ===========================
# DATABASE (Amazon RDS)
# ===========================
# Development (Local MySQL)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASS=root
# DB_NAME=sigap_db

# Production (AWS RDS)
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASS=your-secure-password
DB_NAME=sigap_db

# ===========================
# AWS Configuration
# ===========================
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# ===========================
# S3 & CloudFront
# ===========================
S3_BUCKET_NAME=sigap-storage-bucket-name
CLOUDFRONT_URL=https://d12345abcde.cloudfront.net

# ===========================
# Server Configuration
# ===========================
PORT=5000
NODE_ENV=production

# ===========================
# CORS Configuration
# ===========================
# Development
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Production (AWS)
CORS_ORIGIN=https://your-frontend-domain.com,https://app.yourdomain.com
